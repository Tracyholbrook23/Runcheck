# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
node_modules_old/

# ─── Expo ────────────────────────────────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ─── Native iOS ──────────────────────────────────────────────────────────────
ios/build/
ios/Pods/              # CocoaPods — reproduced via `pod install`
ios/.xcode.env.local

# ─── Native Android ──────────────────────────────────────────────────────────
android/build/
android/app/build/
android/.gradle/
android/.idea/
android/local.properties
android/.cxx/

# ─── Build / Metro cache ─────────────────────────────────────────────────────
build/
.metro-health-check*
.metro-cache/
__pycache__/

# ─── Environment variables ───────────────────────────────────────────────────
# Keep .env.example (template for teammates) — ignore everything else
.env
.env.*
!.env.example

# ─── Secrets / Keys ──────────────────────────────────────────────────────────
serviceAccountKey.json
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
google-services.json
GoogleService-Info.plist

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# ─── Editor / OS artifacts ───────────────────────────────────────────────────
.DS_Store
.idea/
*.orig.*
*.orig
.vscode/settings.json

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Test coverage ───────────────────────────────────────────────────────────
coverage/

# ─── Temp / junk files ───────────────────────────────────────────────────────
package.json.save      # npm temp file — never commit this
*.bak
*.tmp
ios/.xcode.env
